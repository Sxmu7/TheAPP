{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['status'])",
        "players": {
          "$playerId": {
            ".validate": "newData.hasChildren(['name', 'colorIdx', 'drinks'])"
          }
        }
      }
    }
  }
}
